# ══════════════════════════════════════════════════
# CORTEX-PERSIST .gitignore — Sovereign Hygiene
# ══════════════════════════════════════════════════
# Core tracked dirs: cortex/ config/ data/ docs/ examples/
#   experimental/ infra/ notebooks/ scripts/ sdks/ tests/
# Everything else is local-only.
# ══════════════════════════════════════════════════

# ── Security ──────────────────────────────────────
.env
.env.*
*.pem
*.key
*.p12
*.pfx
token.json
credentials.json
**/secrets/
service-account*.json

# ── Dependencies ──────────────────────────────────
node_modules/
.venv/
.venv*/
venv/
env/

# ── Python build artifacts ────────────────────────
__pycache__/
*.pyc
*.pyo
*.egg-info/
dist/
build/
.eggs/

# ── IDE & Editor ──────────────────────────────────
.idea/
.vscode/
*.swp
*.swo
*~

# ── Databases (local) ────────────────────────────
*.db
*.db-journal
*.db-shm
*.db-wal
*.db.bak

# ── Testing & Linting ────────────────────────────
.pytest_cache/
.mypy_cache/
.ruff_cache/
reports/
.coverage
htmlcov/
coverage.xml

# ── OS ────────────────────────────────────────────

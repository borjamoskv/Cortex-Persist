# ══════════════════════════════════════════════════
# CORTEX-PERSIST .gitignore — Sovereign Hygiene
# ══════════════════════════════════════════════════
# Core tracked dirs: cortex/ config/ data/ docs/ examples/
#   experimental/ infra/ notebooks/ scripts/ sdks/ tests/
# Everything else is local-only.
# ══════════════════════════════════════════════════

# ── Security ──────────────────────────────────────
.env
.env.*
!.env.example
*.pem
*.key
*.p12
*.pfx
token.json
credentials.json
**/secrets/
service-account*.json


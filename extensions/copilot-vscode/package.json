{
  "name": "cortex-copilot",
  "displayName": "CORTEX Copilot — Level 3",
  "description": "Inline code suggestion engine powered by CORTEX. Observes, proposes, never acts alone.",
  "version": "0.1.0",
  "publisher": "borjamoskv",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/borjamoskv/cortex-persist"
  },
  "engines": {
    "vscode": "^1.95.0"
  },
  "categories": [
    "Programming Languages",
    "Machine Learning",
    "Other"
  ],
  "keywords": [
    "copilot",
    "ai",
    "autocomplete",
    "inline-completion",
    "cortex"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "cortex-copilot.enable",
        "title": "CORTEX Copilot: Enable"
      },
      {
        "command": "cortex-copilot.disable",
        "title": "CORTEX Copilot: Disable"
      },
      {
        "command": "cortex-copilot.showTelemetry",
        "title": "CORTEX Copilot: Show Telemetry"
      }
    ],
    "configuration": {
      "title": "CORTEX Copilot",
      "properties": {
        "cortex-copilot.serverUrl": {
          "type": "string",
          "default": "ws://localhost:8765",
          "description": "WebSocket URL of the CORTEX CopilotServer backend"
        },
        "cortex-copilot.debounceMs": {
          "type": "number",
          "default": 300,
          "minimum": 50,
          "maximum": 2000,
          "description": "Debounce interval in milliseconds (delay after last keystroke before requesting suggestions)"
        },
        "cortex-copilot.maxSuggestions": {
          "type": "number",
          "default": 3,
          "minimum": 1,
          "maximum": 10,
          "description": "Maximum number of suggestions to request per trigger"
        },
        "cortex-copilot.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable or disable the copilot"
        }
      }
    },
    "keybindings": [
      {
        "key": "tab",
        "command": "cortex-copilot.acceptSuggestion",
        "when": "inlineSuggestionVisible"
      },
      {
        "key": "escape",
        "command": "cortex-copilot.rejectSuggestion",
        "when": "inlineSuggestionVisible"
      }
    ]
  },
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "lint": "eslint src --ext ts"
  },
  "devDependencies": {
    "@types/vscode": "^1.95.0",
    "@types/node": "^22.0.0",
    "typescript": "^5.7.0"
  }
}
